{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@acadid/shared": ["packages/shared/src/index.ts"],
      "@acadid/crypto": ["packages/crypto/src/index.ts"],
      "@acadid/audit": ["packages/audit/src/index.ts"],
      "@acadid/database": ["packages/database/src/index.ts"]
    }
  }
}
