generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LearnerIdentityStatus {
  VERIFIED
  UNVERIFIED
  PENDING_REVIEW
}

enum InstitutionType {
  PRIMARY
  SECONDARY
  TERTIARY
  EXAM_BODY
}

enum InstitutionTier {
  FOUNDING
  ACTIVE
  VERIFIED
}

enum InstitutionStatus {
  ACTIVE
  SUSPENDED
}

enum InstitutionApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeveloperAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum DisputePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum AuthorityGrantStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum EnrolmentStatus {
  ACTIVE
  CLOSED
}

enum ExitType {
  GRADUATE
  TRANSFER
  WITHDRAW
}

enum PeriodType {
  TERM
  SEMESTER
}

enum AcademicRecordStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  PUBLISHED
  AMENDED
}

enum CredentialType {
  TRANSCRIPT
  RESULT_SLIP
  CERTIFICATE
}

enum CredentialStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  SUPERSEDED
  EXPIRED
}

enum AccessGrantScope {
  FULL
  GPA
  SEMESTER
  SUBJECT
}

enum VerificationOutcome {
  CONFIRMED
  DENIED
  DISCREPANCY
  REVOKED
}

enum UserRole {
  ACADID_SUPER_ADMIN
  REGISTRAR
  EXAM_OFFICER
  DATA_ENTRY_OFFICER
  STUDENT
  GUARDIAN
  VERIFIER
}

enum ApiKeyEnvironment {
  SANDBOX
  PRODUCTION
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum ApiKeyOwnerType {
  PRODUCT
  INSTITUTION
}

enum RevenueCategory {
  VERIFICATION_FEE
  CREDENTIAL_EXPORT_FEE
  INSTITUTION_SUBSCRIPTION
}

enum RevenueEntryStatus {
  PENDING
  BILLABLE
  INVOICED
  PAID
  WAIVED
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

model Learner {
  uuid           String                @id @default(uuid()) @db.Uuid
  ain            String                @unique
  fullName       String
  dateOfBirth    DateTime
  phone          String?
  ninEncrypted   String?
  jambId         String?
  identityStatus LearnerIdentityStatus @default(UNVERIFIED)
  guardianId     String?               @db.Uuid
  guardian       Learner?              @relation("LearnerGuardian", fields: [guardianId], references: [uuid])
  dependents     Learner[]             @relation("LearnerGuardian")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  enrolments         Enrolment[]
  credentials        Credential[]
  accessGrants       AccessGrant[]
  studentUserProfile User?
  disputes           Dispute[]

  @@index([fullName, dateOfBirth])
}

model Institution {
  uuid         String            @id @default(uuid()) @db.Uuid
  institutionId String           @unique
  officialName String
  type         InstitutionType
  state        String
  tier         InstitutionTier   @default(FOUNDING)
  signingKeyId String?
  mouSignedAt  DateTime?
  status       InstitutionStatus @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  authorityGrants AuthorityGrant[]
  enrolments      Enrolment[]
  credentials     Credential[]
  users           InstitutionUser[]
  resultBatches   ResultBatch[]
  auditEvents     AuditEvent[]
  apiKeys         ApiKey[]
  applications    InstitutionApplication[]
  developerAccessRequests DeveloperAccessRequest[]
  disputes       Dispute[]
  revenueEntries RevenueLedgerEntry[]
  subscriptions  InstitutionSubscription[]
}

model InstitutionApplication {
  uuid                  String                       @id @default(uuid()) @db.Uuid
  officialName          String
  type                  String
  state                 String
  address               String
  contactPersonName     String
  contactEmail          String
  studentVolume         Int
  documentUploads       Json
  mouAcceptedAt         DateTime?
  status                InstitutionApplicationStatus @default(PENDING)
  reviewFeedback        String?
  reviewedById          String?                      @db.Uuid
  reviewedAt            DateTime?
  approvedInstitutionId String?                      @db.Uuid
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  approvedInstitution Institution? @relation(fields: [approvedInstitutionId], references: [uuid])

  @@index([status, createdAt])
  @@index([contactEmail])
}

model DeveloperAccessRequest {
  uuid            String                       @id @default(uuid()) @db.Uuid
  institutionId   String                       @db.Uuid
  requestedById   String?                      @db.Uuid
  developerName   String
  developerEmail  String
  developerPhone  String?
  reason          String
  requestedScopes String[]
  status          DeveloperAccessRequestStatus @default(PENDING)
  reviewFeedback  String?
  reviewedById    String?                      @db.Uuid
  reviewedAt      DateTime?
  approvedAt      DateTime?
  suspendedAt     DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  institution Institution @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, status])
  @@index([status, createdAt])
  @@index([developerEmail])
}

model User {
  uuid         String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  fullName     String
  role         UserRole
  learnerId    String?   @unique @db.Uuid
  learner      Learner?  @relation(fields: [learnerId], references: [uuid])
  mfaEnabled   Boolean   @default(false)
  totpSecretEncrypted String?
  totpEnabledAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  institutions InstitutionUser[]
  auditEvents  AuditEvent[]
  assignedDisputes Dispute[] @relation("DisputeAssignee")
}

model InstitutionUser {
  uuid          String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  institutionId String      @db.Uuid
  role          UserRole
  createdAt     DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [uuid])
  institution Institution @relation(fields: [institutionId], references: [uuid])

  @@unique([userId, institutionId, role])
}

model AuthorityGrant {
  uuid           String               @id @default(uuid()) @db.Uuid
  institutionId  String               @db.Uuid
  mouDocumentUrl String
  signedByName   String
  signedByTitle  String
  signedAt       DateTime             @default(now())
  effectiveFrom  DateTime
  expiresAt      DateTime?
  permissions    Json
  status         AuthorityGrantStatus @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  institution Institution @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, status])
}

model ApiKey {
  uuid               String            @id @default(uuid()) @db.Uuid
  ownerType          ApiKeyOwnerType   @default(INSTITUTION)
  institutionId      String?           @db.Uuid
  productCode        String?
  productName        String?
  clientId           String            @unique
  clientSecretHash   String
  label              String
  scopes             String[]
  environment        ApiKeyEnvironment @default(SANDBOX)
  status             ApiKeyStatus      @default(ACTIVE)
  rateLimitPerMinute Int               @default(100)
  expiresAt          DateTime?
  lastUsedAt         DateTime?
  revokedAt          DateTime?
  revokedReason      String?
  createdById        String?           @db.Uuid
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  institution Institution? @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, status])
  @@index([ownerType, status])
  @@index([productCode, status])
  @@index([clientId, status])
}

model Enrolment {
  uuid          String          @id @default(uuid()) @db.Uuid
  learnerId     String          @db.Uuid
  institutionId String          @db.Uuid
  studentNumber String
  level         String
  programme     String
  entryDate     DateTime
  exitDate      DateTime?
  exitType      ExitType?
  status        EnrolmentStatus @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  learner         Learner          @relation(fields: [learnerId], references: [uuid])
  institution     Institution      @relation(fields: [institutionId], references: [uuid])
  academicRecords AcademicRecord[]

  @@unique([institutionId, studentNumber, status])
  @@index([learnerId])
}

model ResultBatch {
  uuid          String               @id @default(uuid()) @db.Uuid
  institutionId String               @db.Uuid
  title         String
  status        AcademicRecordStatus @default(DRAFT)
  rejectionCount Int                 @default(0)
  createdById   String              @db.Uuid
  submittedAt   DateTime?
  reviewedAt    DateTime?
  approvedAt    DateTime?
  publishedAt   DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  institution     Institution      @relation(fields: [institutionId], references: [uuid])
  academicRecords AcademicRecord[]

  @@index([institutionId, status])
}

model AcademicRecord {
  uuid          String               @id @default(uuid()) @db.Uuid
  enrolmentId   String               @db.Uuid
  resultBatchId String?              @db.Uuid
  periodType    PeriodType
  periodLabel   String
  subjectCode   String
  subjectName   String
  caScore       Decimal?
  examScore     Decimal?
  totalScore    Decimal
  grade         String
  status        AcademicRecordStatus @default(DRAFT)
  publishedAt   DateTime?
  version       Int                  @default(1)
  supersedesId  String?              @db.Uuid
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  enrolment   Enrolment    @relation(fields: [enrolmentId], references: [uuid])
  resultBatch ResultBatch? @relation(fields: [resultBatchId], references: [uuid])
  credentials Credential[]

  @@index([enrolmentId, periodLabel])
  @@index([status])
}

model Credential {
  uuid             String           @id @default(uuid()) @db.Uuid
  credentialRef    String           @unique
  learnerId        String           @db.Uuid
  institutionId    String           @db.Uuid
  academicRecordId String?          @db.Uuid
  type             CredentialType
  scope            Json
  version          Int              @default(1)
  signature        String?
  vcPayload        Json
  status           CredentialStatus @default(ACTIVE)
  issuedAt         DateTime         @default(now())
  revokedAt        DateTime?
  revocationReason String?

  learner        Learner         @relation(fields: [learnerId], references: [uuid])
  institution    Institution     @relation(fields: [institutionId], references: [uuid])
  academicRecord AcademicRecord? @relation(fields: [academicRecordId], references: [uuid])
  accessGrants   AccessGrant[]
  verifications  VerificationEvent[]
  disputes       Dispute[]
  revenueEntries RevenueLedgerEntry[]

  @@index([learnerId, status])
  @@index([institutionId, status])
}

model AccessGrant {
  uuid           String           @id @default(uuid()) @db.Uuid
  learnerId      String           @db.Uuid
  credentialId   String           @db.Uuid
  tokenHash      String           @unique
  scope          AccessGrantScope
  recipientLabel String
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime         @default(now())
  maxViews       Int?
  viewCount      Int              @default(0)

  learner       Learner             @relation(fields: [learnerId], references: [uuid])
  credential    Credential          @relation(fields: [credentialId], references: [uuid])
  verifications VerificationEvent[]

  @@index([learnerId])
  @@index([credentialId])
}

model VerificationEvent {
  uuid          String              @id @default(uuid()) @db.Uuid
  credentialId  String              @db.Uuid
  accessGrantId String?             @db.Uuid
  verifierType  String
  verifierName  String?
  verifierEmailEncrypted String?
  ipAddressHash String?
  outcome       VerificationOutcome
  verifiedAt    DateTime            @default(now())
  scopeViewed   Json

  credential  Credential   @relation(fields: [credentialId], references: [uuid])
  accessGrant AccessGrant? @relation(fields: [accessGrantId], references: [uuid])
  revenueEntries RevenueLedgerEntry[]

  @@index([credentialId, verifiedAt])
}

model RevenueLedgerEntry {
  uuid                String             @id @default(uuid()) @db.Uuid
  category            RevenueCategory
  status              RevenueEntryStatus @default(BILLABLE)
  amountMinor         Int
  currency            String             @default("NGN")
  institutionId       String?            @db.Uuid
  credentialId        String?            @db.Uuid
  verificationEventId String?            @db.Uuid
  sourceType          String
  sourceId            String?
  description         String
  occurredAt          DateTime           @default(now())
  invoicedAt          DateTime?
  paidAt              DateTime?
  waivedAt            DateTime?
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  institution       Institution?       @relation(fields: [institutionId], references: [uuid])
  credential        Credential?        @relation(fields: [credentialId], references: [uuid])
  verificationEvent VerificationEvent? @relation(fields: [verificationEventId], references: [uuid])

  @@index([category, occurredAt])
  @@index([status, occurredAt])
  @@index([institutionId, occurredAt])
  @@index([sourceType, sourceId])
}

model InstitutionSubscription {
  uuid               String             @id @default(uuid()) @db.Uuid
  institutionId      String             @db.Uuid
  planCode           String
  status             SubscriptionStatus @default(TRIALING)
  amountMinor        Int
  currency           String             @default("NGN")
  billingInterval    String             @default("MONTHLY")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingAt      DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  institution Institution @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, status])
  @@index([status, nextBillingAt])
}

model Dispute {
  uuid               String          @id @default(uuid()) @db.Uuid
  title              String
  description        String
  category           String          @default("GENERAL")
  priority           DisputePriority @default(NORMAL)
  status             DisputeStatus   @default(OPEN)
  institutionId      String?         @db.Uuid
  learnerId          String?         @db.Uuid
  credentialId       String?         @db.Uuid
  reporterName       String?
  reporterEmail      String?
  assignedToId       String?         @db.Uuid
  institutionNotice  String?
  noticeSentAt       DateTime?
  escalatedAt        DateTime?
  resolvedAt         DateTime?
  resolutionNote     String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  institution Institution? @relation(fields: [institutionId], references: [uuid])
  learner     Learner?     @relation(fields: [learnerId], references: [uuid])
  credential  Credential?  @relation(fields: [credentialId], references: [uuid])
  assignedTo  User?        @relation("DisputeAssignee", fields: [assignedToId], references: [uuid])

  @@index([status, createdAt])
  @@index([institutionId, status])
  @@index([learnerId])
  @@index([credentialId])
  @@index([assignedToId])
}

model ImportFile {
  uuid          String   @id @default(uuid()) @db.Uuid
  institutionId String   @db.Uuid
  filename      String
  storageUrl    String
  kind          String
  checksum      String?
  uploadedById  String   @db.Uuid
  createdAt     DateTime @default(now())
}

model MouDocument {
  uuid          String   @id @default(uuid()) @db.Uuid
  institutionId String   @db.Uuid
  storageUrl    String
  checksum      String?
  uploadedById  String   @db.Uuid
  createdAt     DateTime @default(now())
}

model AuditEvent {
  uuid          String   @id @default(uuid()) @db.Uuid
  actorId       String?  @db.Uuid
  actorRole     UserRole?
  institutionId String?  @db.Uuid
  action        String
  targetType    String
  targetId      String?
  outcome       String
  reason        String?
  ipAddressHash String?
  metadata      Json?
  createdAt     DateTime @default(now())

  actor       User?        @relation(fields: [actorId], references: [uuid])
  institution Institution? @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, createdAt])
  @@index([targetType, targetId])
}
