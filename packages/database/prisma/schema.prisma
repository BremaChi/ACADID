generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LearnerIdentityStatus {
  VERIFIED
  UNVERIFIED
  PENDING_REVIEW
}

enum InstitutionType {
  PRIMARY
  SECONDARY
  TERTIARY
  EXAM_BODY
}

enum InstitutionTier {
  FOUNDING
  ACTIVE
  VERIFIED
}

enum InstitutionStatus {
  ACTIVE
  SUSPENDED
}

enum InstitutionApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeveloperAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum RecordRequestStatus {
  SUBMITTED
  AWAITING_PAYMENT
  ASSIGNED
  INSTITUTION_REVIEW
  NEEDS_MORE_INFORMATION
  APPROVED
  REJECTED
  FULFILLED
  DISPUTED
  ESCALATED
  CANCELLED
}

enum RecordRequestPaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  WAIVED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum DisputePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum AuthorityGrantStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum EnrolmentStatus {
  ACTIVE
  PENDING_ROLLOVER
  PROMOTED
  REPEATED
  TRANSFERRED_OUT
  WITHDRAWN
  GRADUATED
  SUSPENDED
  SEALED
  CLOSED
}

enum ExitType {
  GRADUATE
  TRANSFER
  WITHDRAW
}

enum PeriodType {
  TERM
  SEMESTER
}

enum AcademicSessionStatus {
  DRAFT
  ACTIVE
  CLOSED
  SEALED
}

enum AcademicStructureType {
  LEVEL
  CLASS
  ARM
  STREAM
  SUBJECT
  FACULTY
  DEPARTMENT
  PROGRAMME
  COURSE
}

enum AcademicStructureStatus {
  ACTIVE
  ARCHIVED
}

enum ResultUploadMode {
  SUBJECT_BY_SUBJECT
  MASTER_SHEET
  COURSE_BASED
  MANUAL_ENTRY
}

enum AcademicRecordStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  PUBLISHED
  REJECTED
  SEALED
  AMENDED
}

enum RolloverDecision {
  PROMOTED
  REPEATED
  TRANSFERRED_OUT
  WITHDRAWN
  GRADUATED
  SUSPENDED
  SEALED
}

enum RolloverStatus {
  PENDING_ROLLOVER
  APPROVED
  CANCELLED
}

enum CredentialType {
  TRANSCRIPT
  RESULT_SLIP
  CERTIFICATE
}

enum CredentialStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  SUPERSEDED
  EXPIRED
}

enum AccessGrantScope {
  FULL
  GPA
  SEMESTER
  SUBJECT
}

enum VerificationOutcome {
  CONFIRMED
  DENIED
  DISCREPANCY
  REVOKED
}

enum UserRole {
  ACADID_SUPER_ADMIN
  REGISTRAR
  EXAM_OFFICER
  DATA_ENTRY_OFFICER
  DEPARTMENTAL_OFFICER
  READ_ONLY
  STUDENT
  GUARDIAN
  VERIFIER
}

enum InstitutionUserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED
}

enum ApiKeyEnvironment {
  SANDBOX
  PRODUCTION
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum ApiKeyOwnerType {
  PRODUCT
  INSTITUTION
}

enum RevenueCategory {
  VERIFICATION_FEE
  CREDENTIAL_EXPORT_FEE
  INSTITUTION_SUBSCRIPTION
}

enum RevenueEntryStatus {
  PENDING
  BILLABLE
  INVOICED
  PAID
  WAIVED
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum BackgroundJobType {
  BULK_STUDENT_UPLOAD
  RESULT_BATCH_VALIDATION
  CREDENTIAL_GENERATION
  PDF_GENERATION
  SMS_EMAIL_DELIVERY
  PAYSTACK_PAYMENT_CONFIRMATION
  RECORD_REQUEST_DEADLINE
  WEBHOOK_DELIVERY
  PUSH_NOTIFICATION
  LIVE_RESULTS_CALLBACK
  EXAM_BODY_INGEST
}

enum BackgroundJobStatus {
  QUEUED
  RUNNING
  RETRYING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum DomainEventStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  RETRYING
  FAILED
  CANCELLED
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model Learner {
  uuid           String                @id @default(uuid()) @db.Uuid
  ain            String                @unique
  fullName       String
  dateOfBirth    DateTime
  phone          String?
  ninEncrypted   String?
  jambId         String?
  identityStatus LearnerIdentityStatus @default(UNVERIFIED)
  guardianId     String?               @db.Uuid
  guardian       Learner?              @relation("LearnerGuardian", fields: [guardianId], references: [uuid])
  dependents     Learner[]             @relation("LearnerGuardian")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  enrolments         Enrolment[]
  credentials        Credential[]
  accessGrants       AccessGrant[]
  studentUserProfile User?
  disputes           Dispute[]
  recordRequests     RecordRequest[]
  rolloverRecords    RolloverRecord[]
  notifications      Notification[]

  @@index([fullName, dateOfBirth])
}

model Institution {
  uuid          String            @id @default(uuid()) @db.Uuid
  institutionId String            @unique
  officialName  String
  type          InstitutionType
  state         String
  tier          InstitutionTier   @default(FOUNDING)
  signingKeyId  String?
  mouSignedAt   DateTime?
  status        InstitutionStatus @default(ACTIVE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  authorityGrants         AuthorityGrant[]
  enrolments              Enrolment[]
  academicSessions        AcademicSession[]
  academicStructures      AcademicStructure[]
  credentials             Credential[]
  users                   InstitutionUser[]
  resultBatches           ResultBatch[]
  rolloverRecords         RolloverRecord[]
  auditEvents             AuditEvent[]
  apiKeys                 ApiKey[]
  applications            InstitutionApplication[]
  developerAccessRequests DeveloperAccessRequest[]
  recordRequests          RecordRequest[]
  disputes                Dispute[]
  revenueEntries          RevenueLedgerEntry[]
  subscriptions           InstitutionSubscription[]
  backgroundJobs          BackgroundJob[]
  domainEvents            DomainEvent[]
  webhookDeliveries       WebhookDelivery[]
  notifications           Notification[]
}

model InstitutionApplication {
  uuid                  String                       @id @default(uuid()) @db.Uuid
  officialName          String
  type                  String
  state                 String
  address               String
  contactPersonName     String
  contactEmail          String
  studentVolume         Int
  documentUploads       Json
  mouAcceptedAt         DateTime?
  status                InstitutionApplicationStatus @default(PENDING)
  reviewFeedback        String?
  reviewedById          String?                      @db.Uuid
  reviewedAt            DateTime?
  approvedInstitutionId String?                      @db.Uuid
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  approvedInstitution Institution? @relation(fields: [approvedInstitutionId], references: [uuid])

  @@index([status, createdAt])
  @@index([contactEmail])
}

model DeveloperAccessRequest {
  uuid            String                       @id @default(uuid()) @db.Uuid
  institutionId   String                       @db.Uuid
  requestedById   String?                      @db.Uuid
  developerName   String
  developerEmail  String
  developerPhone  String?
  reason          String
  requestedScopes String[]
  status          DeveloperAccessRequestStatus @default(PENDING)
  reviewFeedback  String?
  reviewedById    String?                      @db.Uuid
  reviewedAt      DateTime?
  approvedAt      DateTime?
  suspendedAt     DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  institution Institution @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, status])
  @@index([status, createdAt])
  @@index([developerEmail])
}

model User {
  uuid                String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  passwordHash        String
  fullName            String
  phone               String?
  role                UserRole
  learnerId           String?   @unique @db.Uuid
  learner             Learner?  @relation(fields: [learnerId], references: [uuid])
  mfaEnabled          Boolean   @default(false)
  totpSecretEncrypted String?
  totpEnabledAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  institutions            InstitutionUser[]
  invitedInstitutionUsers InstitutionUser[] @relation("InstitutionUserInviter")
  auditEvents             AuditEvent[]
  assignedDisputes        Dispute[]         @relation("DisputeAssignee")
  assignedRecordRequests  RecordRequest[]   @relation("RecordRequestAssignee")
  platformSettings        PlatformSetting[]
  mfaRecoveryCodes        MfaRecoveryCode[]
  backgroundJobs          BackgroundJob[]
  notifications           Notification[]
}

model InstitutionUser {
  uuid              String                @id @default(uuid()) @db.Uuid
  userId            String                @db.Uuid
  institutionId     String                @db.Uuid
  role              UserRole
  status            InstitutionUserStatus @default(ACTIVE)
  permissions       String[]              @default([])
  assignedScopes    Json                  @default("[]")
  invitedById       String?               @db.Uuid
  inviteTokenHash   String?               @unique
  invitedAt         DateTime?
  inviteExpiresAt   DateTime?
  inviteAcceptedAt  DateTime?
  lastLoginAt       DateTime?
  twoFactorRequired Boolean               @default(false)
  suspendedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user                      User                @relation(fields: [userId], references: [uuid])
  institution               Institution         @relation(fields: [institutionId], references: [uuid])
  invitedBy                 User?               @relation("InstitutionUserInviter", fields: [invitedById], references: [uuid])
  createdAcademicSessions   AcademicSession[]   @relation("AcademicSessionCreator")
  createdAcademicStructures AcademicStructure[] @relation("AcademicStructureCreator")
  createdResultBatches      ResultBatch[]       @relation("ResultBatchCreator")
  reviewedResultBatches     ResultBatch[]       @relation("ResultBatchReviewer")
  approvedResultBatches     ResultBatch[]       @relation("ResultBatchApprover")
  createdRollovers          RolloverRecord[]    @relation("RolloverCreator")
  approvedRollovers         RolloverRecord[]    @relation("RolloverApprover")

  @@unique([userId, institutionId, role])
  @@index([institutionId, status])
  @@index([userId, status])
  @@index([inviteTokenHash])
}

model AuthorityGrant {
  uuid           String               @id @default(uuid()) @db.Uuid
  institutionId  String               @db.Uuid
  mouDocumentUrl String
  signedByName   String
  signedByTitle  String
  signedAt       DateTime             @default(now())
  effectiveFrom  DateTime
  expiresAt      DateTime?
  permissions    Json
  status         AuthorityGrantStatus @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  institution Institution @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, status])
}

model ApiKey {
  uuid               String            @id @default(uuid()) @db.Uuid
  ownerType          ApiKeyOwnerType   @default(INSTITUTION)
  institutionId      String?           @db.Uuid
  productCode        String?
  productName        String?
  clientId           String            @unique
  clientSecretHash   String
  label              String
  scopes             String[]
  environment        ApiKeyEnvironment @default(SANDBOX)
  status             ApiKeyStatus      @default(ACTIVE)
  rateLimitPerMinute Int               @default(100)
  expiresAt          DateTime?
  lastUsedAt         DateTime?
  revokedAt          DateTime?
  revokedReason      String?
  createdById        String?           @db.Uuid
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  institution Institution? @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, status])
  @@index([ownerType, status])
  @@index([productCode, status])
  @@index([clientId, status])
}

model Enrolment {
  uuid              String          @id @default(uuid()) @db.Uuid
  learnerId         String          @db.Uuid
  institutionId     String          @db.Uuid
  academicSessionId String?         @db.Uuid
  structureScopeId  String?         @db.Uuid
  studentNumber     String
  level             String
  programme         String
  entryDate         DateTime
  exitDate          DateTime?
  exitType          ExitType?
  status            EnrolmentStatus @default(ACTIVE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  learner         Learner            @relation(fields: [learnerId], references: [uuid])
  institution     Institution        @relation(fields: [institutionId], references: [uuid])
  academicSession AcademicSession?   @relation(fields: [academicSessionId], references: [uuid])
  structureScope  AcademicStructure? @relation(fields: [structureScopeId], references: [uuid])
  academicRecords AcademicRecord[]
  rolloverRecords RolloverRecord[]

  @@unique([institutionId, studentNumber, status])
  @@index([learnerId])
  @@index([institutionId, academicSessionId, status])
  @@index([structureScopeId, status])
}

model AcademicSession {
  uuid          String                @id @default(uuid()) @db.Uuid
  institutionId String                @db.Uuid
  sessionLabel  String
  periodType    PeriodType
  periodLabel   String
  startDate     DateTime?
  endDate       DateTime?
  status        AcademicSessionStatus @default(DRAFT)
  isCurrent     Boolean               @default(false)
  createdById   String?               @db.Uuid
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  institution     Institution      @relation(fields: [institutionId], references: [uuid])
  createdBy       InstitutionUser? @relation("AcademicSessionCreator", fields: [createdById], references: [uuid])
  enrolments      Enrolment[]
  resultBatches   ResultBatch[]
  academicRecords AcademicRecord[]
  rolloversFrom   RolloverRecord[] @relation("RolloverFromSession")
  rolloversTo     RolloverRecord[] @relation("RolloverToSession")

  @@unique([institutionId, sessionLabel, periodType, periodLabel])
  @@index([institutionId, status])
  @@index([institutionId, isCurrent])
  @@index([createdById])
}

model AcademicStructure {
  uuid          String                  @id @default(uuid()) @db.Uuid
  institutionId String                  @db.Uuid
  parentId      String?                 @db.Uuid
  type          AcademicStructureType
  name          String
  code          String?
  creditUnits   Int?
  metadata      Json?
  status        AcademicStructureStatus @default(ACTIVE)
  createdById   String?                 @db.Uuid
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  institution     Institution         @relation(fields: [institutionId], references: [uuid])
  parent          AcademicStructure?  @relation("AcademicStructureTree", fields: [parentId], references: [uuid])
  children        AcademicStructure[] @relation("AcademicStructureTree")
  createdBy       InstitutionUser?    @relation("AcademicStructureCreator", fields: [createdById], references: [uuid])
  enrolments      Enrolment[]
  resultBatches   ResultBatch[]
  academicRecords AcademicRecord[]
  rolloversFrom   RolloverRecord[]    @relation("RolloverFromStructure")
  rolloversTo     RolloverRecord[]    @relation("RolloverToStructure")

  @@index([institutionId, type, status])
  @@index([institutionId, parentId])
  @@index([code])
  @@index([createdById])
}

model ResultBatch {
  uuid                        String               @id @default(uuid()) @db.Uuid
  institutionId               String               @db.Uuid
  academicSessionId           String?              @db.Uuid
  structureScopeId            String?              @db.Uuid
  uploadMode                  ResultUploadMode     @default(MASTER_SHEET)
  title                       String
  batchLabel                  String?
  status                      AcademicRecordStatus @default(DRAFT)
  rejectionCount              Int                  @default(0)
  createdById                 String               @db.Uuid
  createdByInstitutionUserId  String?              @db.Uuid
  reviewedByInstitutionUserId String?              @db.Uuid
  approvedByInstitutionUserId String?              @db.Uuid
  recordCount                 Int                  @default(0)
  validationSummary           Json?
  rejectionReason             String?
  submittedAt                 DateTime?
  reviewedAt                  DateTime?
  approvedAt                  DateTime?
  publishedAt                 DateTime?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  institution               Institution        @relation(fields: [institutionId], references: [uuid])
  academicSession           AcademicSession?   @relation(fields: [academicSessionId], references: [uuid])
  structureScope            AcademicStructure? @relation(fields: [structureScopeId], references: [uuid])
  createdByInstitutionUser  InstitutionUser?   @relation("ResultBatchCreator", fields: [createdByInstitutionUserId], references: [uuid])
  reviewedByInstitutionUser InstitutionUser?   @relation("ResultBatchReviewer", fields: [reviewedByInstitutionUserId], references: [uuid])
  approvedByInstitutionUser InstitutionUser?   @relation("ResultBatchApprover", fields: [approvedByInstitutionUserId], references: [uuid])
  academicRecords           AcademicRecord[]

  @@index([institutionId, status])
  @@index([institutionId, academicSessionId, status])
  @@index([structureScopeId, status])
  @@index([createdByInstitutionUserId])
  @@index([reviewedByInstitutionUserId])
  @@index([approvedByInstitutionUserId])
}

model AcademicRecord {
  uuid              String               @id @default(uuid()) @db.Uuid
  enrolmentId       String               @db.Uuid
  resultBatchId     String?              @db.Uuid
  academicSessionId String?              @db.Uuid
  structureScopeId  String?              @db.Uuid
  periodType        PeriodType
  periodLabel       String
  subjectCode       String
  subjectName       String
  caScore           Decimal?
  examScore         Decimal?
  totalScore        Decimal
  grade             String
  status            AcademicRecordStatus @default(DRAFT)
  publishedAt       DateTime?
  version           Int                  @default(1)
  supersedesId      String?              @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  enrolment       Enrolment          @relation(fields: [enrolmentId], references: [uuid])
  resultBatch     ResultBatch?       @relation(fields: [resultBatchId], references: [uuid])
  academicSession AcademicSession?   @relation(fields: [academicSessionId], references: [uuid])
  structureScope  AcademicStructure? @relation(fields: [structureScopeId], references: [uuid])
  credentials     Credential[]

  @@index([enrolmentId, periodLabel])
  @@index([status])
  @@index([academicSessionId, status])
  @@index([structureScopeId, status])
  @@index([resultBatchId, status])
}

model RolloverRecord {
  uuid            String           @id @default(uuid()) @db.Uuid
  institutionId   String           @db.Uuid
  learnerId       String           @db.Uuid
  enrolmentId     String?          @db.Uuid
  fromSessionId   String           @db.Uuid
  toSessionId     String?          @db.Uuid
  fromStructureId String?          @db.Uuid
  toStructureId   String?          @db.Uuid
  decision        RolloverDecision
  status          RolloverStatus   @default(PENDING_ROLLOVER)
  reason          String?
  createdById     String?          @db.Uuid
  approvedById    String?          @db.Uuid
  approvedAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  institution   Institution        @relation(fields: [institutionId], references: [uuid])
  learner       Learner            @relation(fields: [learnerId], references: [uuid])
  enrolment     Enrolment?         @relation(fields: [enrolmentId], references: [uuid])
  fromSession   AcademicSession    @relation("RolloverFromSession", fields: [fromSessionId], references: [uuid])
  toSession     AcademicSession?   @relation("RolloverToSession", fields: [toSessionId], references: [uuid])
  fromStructure AcademicStructure? @relation("RolloverFromStructure", fields: [fromStructureId], references: [uuid])
  toStructure   AcademicStructure? @relation("RolloverToStructure", fields: [toStructureId], references: [uuid])
  createdBy     InstitutionUser?   @relation("RolloverCreator", fields: [createdById], references: [uuid])
  approvedBy    InstitutionUser?   @relation("RolloverApprover", fields: [approvedById], references: [uuid])

  @@index([institutionId, status])
  @@index([learnerId, createdAt])
  @@index([fromSessionId, status])
  @@index([toSessionId, status])
  @@index([fromStructureId])
  @@index([toStructureId])
  @@index([approvedById])
}

model Credential {
  uuid             String           @id @default(uuid()) @db.Uuid
  credentialRef    String           @unique
  learnerId        String           @db.Uuid
  institutionId    String           @db.Uuid
  academicRecordId String?          @db.Uuid
  type             CredentialType
  scope            Json
  version          Int              @default(1)
  signature        String?
  vcPayload        Json
  status           CredentialStatus @default(ACTIVE)
  issuedAt         DateTime         @default(now())
  revokedAt        DateTime?
  revocationReason String?

  learner        Learner              @relation(fields: [learnerId], references: [uuid])
  institution    Institution          @relation(fields: [institutionId], references: [uuid])
  academicRecord AcademicRecord?      @relation(fields: [academicRecordId], references: [uuid])
  accessGrants   AccessGrant[]
  verifications  VerificationEvent[]
  disputes       Dispute[]
  revenueEntries RevenueLedgerEntry[]

  @@index([learnerId, status])
  @@index([institutionId, status])
}

model AccessGrant {
  uuid           String           @id @default(uuid()) @db.Uuid
  learnerId      String           @db.Uuid
  credentialId   String           @db.Uuid
  tokenHash      String           @unique
  scope          AccessGrantScope
  recipientLabel String
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime         @default(now())
  maxViews       Int?
  viewCount      Int              @default(0)

  learner       Learner             @relation(fields: [learnerId], references: [uuid])
  credential    Credential          @relation(fields: [credentialId], references: [uuid])
  verifications VerificationEvent[]

  @@index([learnerId])
  @@index([credentialId])
}

model VerificationEvent {
  uuid                   String              @id @default(uuid()) @db.Uuid
  credentialId           String              @db.Uuid
  accessGrantId          String?             @db.Uuid
  verifierType           String
  verifierName           String?
  verifierEmailEncrypted String?
  ipAddressHash          String?
  outcome                VerificationOutcome
  verifiedAt             DateTime            @default(now())
  scopeViewed            Json

  credential     Credential           @relation(fields: [credentialId], references: [uuid])
  accessGrant    AccessGrant?         @relation(fields: [accessGrantId], references: [uuid])
  revenueEntries RevenueLedgerEntry[]

  @@index([credentialId, verifiedAt])
}

model RevenueLedgerEntry {
  uuid                String             @id @default(uuid()) @db.Uuid
  category            RevenueCategory
  status              RevenueEntryStatus @default(BILLABLE)
  amountMinor         Int
  currency            String             @default("NGN")
  institutionId       String?            @db.Uuid
  credentialId        String?            @db.Uuid
  verificationEventId String?            @db.Uuid
  sourceType          String
  sourceId            String?
  description         String
  occurredAt          DateTime           @default(now())
  invoicedAt          DateTime?
  paidAt              DateTime?
  waivedAt            DateTime?
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  institution       Institution?       @relation(fields: [institutionId], references: [uuid])
  credential        Credential?        @relation(fields: [credentialId], references: [uuid])
  verificationEvent VerificationEvent? @relation(fields: [verificationEventId], references: [uuid])

  @@index([category, occurredAt])
  @@index([status, occurredAt])
  @@index([institutionId, occurredAt])
  @@index([sourceType, sourceId])
}

model InstitutionSubscription {
  uuid               String             @id @default(uuid()) @db.Uuid
  institutionId      String             @db.Uuid
  planCode           String
  status             SubscriptionStatus @default(TRIALING)
  amountMinor        Int
  currency           String             @default("NGN")
  billingInterval    String             @default("MONTHLY")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingAt      DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  institution Institution @relation(fields: [institutionId], references: [uuid])

  @@index([institutionId, status])
  @@index([status, nextBillingAt])
}

model PlatformSetting {
  uuid        String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       Json
  updatedById String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation(fields: [updatedById], references: [uuid])

  @@index([updatedAt])
}

model MfaRecoveryCode {
  uuid      String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [uuid])

  @@index([userId, usedAt])
  @@index([createdAt])
}

model Dispute {
  uuid              String          @id @default(uuid()) @db.Uuid
  title             String
  description       String
  category          String          @default("GENERAL")
  priority          DisputePriority @default(NORMAL)
  status            DisputeStatus   @default(OPEN)
  institutionId     String?         @db.Uuid
  learnerId         String?         @db.Uuid
  credentialId      String?         @db.Uuid
  reporterName      String?
  reporterEmail     String?
  assignedToId      String?         @db.Uuid
  institutionNotice String?
  noticeSentAt      DateTime?
  escalatedAt       DateTime?
  resolvedAt        DateTime?
  resolutionNote    String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  institution Institution? @relation(fields: [institutionId], references: [uuid])
  learner     Learner?     @relation(fields: [learnerId], references: [uuid])
  credential  Credential?  @relation(fields: [credentialId], references: [uuid])
  assignedTo  User?        @relation("DisputeAssignee", fields: [assignedToId], references: [uuid])

  @@index([status, createdAt])
  @@index([institutionId, status])
  @@index([learnerId])
  @@index([credentialId])
  @@index([assignedToId])
}

model RecordRequest {
  uuid                     String                     @id @default(uuid()) @db.Uuid
  requestId                String                     @unique
  learnerId                String?                    @db.Uuid
  institutionId            String?                    @db.Uuid
  institutionNameSubmitted String
  educationLevel           String
  yearsAttendedFrom        Int?
  yearsAttendedTo          Int?
  studentNumber            String?
  departmentOrClass        String?
  recordTypesRequested     String[]
  proofDocumentUrls        String[]
  status                   RecordRequestStatus        @default(SUBMITTED)
  paymentStatus            RecordRequestPaymentStatus @default(PENDING)
  paymentReference         String?
  amountMinor              Int?
  currency                 String                     @default("NGN")
  deadlineAt               DateTime?
  assignedToId             String?                    @db.Uuid
  requesterName            String?
  requesterEmail           String?
  rejectionReason          String?
  escalationReason         String?
  resolutionNote           String?
  notes                    Json?
  submittedAt              DateTime                   @default(now())
  assignedAt               DateTime?
  fulfilledAt              DateTime?
  rejectedAt               DateTime?
  escalatedAt              DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  learner     Learner?     @relation(fields: [learnerId], references: [uuid])
  institution Institution? @relation(fields: [institutionId], references: [uuid])
  assignedTo  User?        @relation("RecordRequestAssignee", fields: [assignedToId], references: [uuid])

  @@index([status, createdAt])
  @@index([institutionId, status])
  @@index([learnerId, createdAt])
  @@index([requestId])
  @@index([assignedToId, status])
}

model ImportFile {
  uuid          String   @id @default(uuid()) @db.Uuid
  institutionId String   @db.Uuid
  filename      String
  storageUrl    String
  kind          String
  checksum      String?
  uploadedById  String   @db.Uuid
  createdAt     DateTime @default(now())
}

model MouDocument {
  uuid          String   @id @default(uuid()) @db.Uuid
  institutionId String   @db.Uuid
  storageUrl    String
  checksum      String?
  uploadedById  String   @db.Uuid
  createdAt     DateTime @default(now())
}

model AuditEvent {
  uuid          String    @id @default(uuid()) @db.Uuid
  requestId     String?
  actorType     String?
  actorUserId   String?   @db.Uuid
  clientId      String?
  actorId       String?   @db.Uuid
  actorRole     UserRole?
  institutionId String?   @db.Uuid
  role          String?
  endpoint      String?
  httpMethod    String?
  action        String
  targetType    String
  targetId      String?
  entityType    String?
  entityId      String?
  outcome       String
  reason        String?
  ipAddressHash String?
  userAgentHash String?
  metadata      Json?
  createdAt     DateTime  @default(now())

  actor       User?        @relation(fields: [actorId], references: [uuid])
  institution Institution? @relation(fields: [institutionId], references: [uuid])

  @@index([requestId])
  @@index([actorType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([clientId, createdAt])
  @@index([institutionId, createdAt])
  @@index([endpoint, createdAt])
  @@index([targetType, targetId])
  @@index([entityType, entityId])
}

model BackgroundJob {
  uuid              String              @id @default(uuid()) @db.Uuid
  type              BackgroundJobType
  queue             String
  status            BackgroundJobStatus @default(QUEUED)
  institutionId     String?             @db.Uuid
  createdById       String?             @db.Uuid
  relatedEntityType String?
  relatedEntityId   String?
  priority          Int                 @default(0)
  payload           Json
  result            Json?
  error             String?
  progress          Int                 @default(0)
  attempts          Int                 @default(0)
  maxAttempts       Int                 @default(3)
  runAfter          DateTime            @default(now())
  lockedAt          DateTime?
  lockedBy          String?
  startedAt         DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  institution       Institution?      @relation(fields: [institutionId], references: [uuid])
  createdBy         User?             @relation(fields: [createdById], references: [uuid])
  domainEvents      DomainEvent[]
  webhookDeliveries WebhookDelivery[]
  notifications     Notification[]

  @@index([queue, status, runAfter, priority])
  @@index([institutionId, status, createdAt])
  @@index([type, status, createdAt])
  @@index([relatedEntityType, relatedEntityId])
}

model DomainEvent {
  uuid          String            @id @default(uuid()) @db.Uuid
  type          String
  aggregateType String
  aggregateId   String
  institutionId String?           @db.Uuid
  jobId         String?           @db.Uuid
  payload       Json
  status        DomainEventStatus @default(PENDING)
  attempts      Int               @default(0)
  lastError     String?
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())

  institution       Institution?      @relation(fields: [institutionId], references: [uuid])
  job               BackgroundJob?    @relation(fields: [jobId], references: [uuid])
  webhookDeliveries WebhookDelivery[]

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([aggregateType, aggregateId])
  @@index([institutionId, createdAt])
  @@index([jobId])
}

model WebhookDelivery {
  uuid           String                @id @default(uuid()) @db.Uuid
  jobId          String?               @db.Uuid
  eventId        String?               @db.Uuid
  institutionId  String?               @db.Uuid
  targetUrl      String
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                   @default(0)
  nextAttemptAt  DateTime              @default(now())
  lastStatusCode Int?
  lastError      String?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  job         BackgroundJob? @relation(fields: [jobId], references: [uuid])
  event       DomainEvent?   @relation(fields: [eventId], references: [uuid])
  institution Institution?   @relation(fields: [institutionId], references: [uuid])

  @@index([status, nextAttemptAt])
  @@index([institutionId, status])
  @@index([eventType, createdAt])
  @@index([jobId])
  @@index([eventId])
}

model Notification {
  uuid          String              @id @default(uuid()) @db.Uuid
  jobId         String?             @db.Uuid
  institutionId String?             @db.Uuid
  learnerId     String?             @db.Uuid
  userId        String?             @db.Uuid
  channel       NotificationChannel
  type          String
  title         String
  body          String
  payload       Json?
  status        NotificationStatus  @default(PENDING)
  sentAt        DateTime?
  failedAt      DateTime?
  error         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  job         BackgroundJob? @relation(fields: [jobId], references: [uuid])
  institution Institution?   @relation(fields: [institutionId], references: [uuid])
  learner     Learner?       @relation(fields: [learnerId], references: [uuid])
  user        User?          @relation(fields: [userId], references: [uuid])

  @@index([status, createdAt])
  @@index([channel, status])
  @@index([institutionId, status])
  @@index([learnerId, status])
  @@index([userId, status])
  @@index([jobId])
}
